# Runtime
APP_ENV=local
APP_NAME=Hybride PageIndex RAG
LOG_LEVEL=INFO
USE_DATABASE=false
USE_QDRANT=false

# Authentication / authorization
REQUIRE_AUTH=false
AUTH_SECRET=change-me-auth-secret
AUTH_TOKEN_TTL_MINUTES=720
# Comma-separated username:password:role triples (role: admin sees all documents)
AUTH_USERS=admin:admin:admin
MINERU_COMMAND=mineru
MINERU_BACKEND=pipeline
# MinerU speed knobs. On CPU-only machines parsing is slow (~1-3 min for ~8 pages):
# - MINERU_METHOD=txt skips OCR for born-digital PDFs (much faster, no quality loss there)
# - MINERU_FORMULA/MINERU_TABLE=false skip the expensive formula/table models
MINERU_METHOD=auto
MINERU_FORMULA=true
MINERU_TABLE=true
MINERU_TIMEOUT_SECONDS=1200
# Strongly recommended so MinerU runs off the request path (uploads return immediately).
USE_BACKGROUND_WORKER=true
WORKER_MAX_WORKERS=2

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=uploads

# PostgreSQL
# Use 127.0.0.1 on Windows to avoid localhost DNS latency.
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=postgres

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=km_nodes
QDRANT_VECTOR_SIZE=1024
EMBEDDING_TIMEOUT_SECONDS=3

# Retrieval strategy: dense | bm25 | hybrid (hybrid fuses dense + BM25 via RRF)
RETRIEVAL_STRATEGY=hybrid
RETRIEVAL_RERANK=true
BM25_K1=1.5
BM25_B=0.75
# Page-level retrieval (tunable via backend/eval A/B). node_hits = top TOC-node
# hits unioned into the rerank pool; citation_pages = top reranked pages cited.
# node_hits=8 was tuned with the eval harness (beats 5 and 10 on page hit rate).
RETRIEVAL_NODE_HITS=8
RETRIEVAL_CITATION_PAGES=2

# LiteLLM / local LLM
USE_AGNO=false
# LLM TOC summaries = one LLM call per TOC node (slow on large trees). Off = fast extractive.
LLM_TOC_SUMMARY=false
LITELLM_BASE_URL=http://127.0.0.1:4001/v1
LITELLM_API_KEY=change-me
MODEL_ID=qwen35-27b
SYNTHESIS_TIMEOUT_SECONDS=20

# Embeddings
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
EMBEDDING_CONTEXT_LENGTH=4096

# Observability (OpenTelemetry -> Phoenix)
# Leave PHOENIX_ENDPOINT empty to disable trace export. Requires the optional
# extra: `uv sync --extra observability`. Phoenix default OTLP endpoint:
# PHOENIX_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_ENDPOINT=
PHOENIX_PROJECT=hybride-pageindex-rag
PHOENIX_PROTOCOL=http/protobuf
